# ============================================================
# AEGIS configuration
# With nothing set, AEGIS runs fully offline: mock model, sqlite
# audit, in-memory event bus, no auth. Switch on the hardened
# paths by setting the variables below.
# ============================================================

# ---- model provider ----
# "mock" = deterministic offline vulnerable model. "regolo" = real LLM.
AEGIS_MODE=mock
REGOLO_BASE_URL=https://api.regolo.ai/v1
REGOLO_API_KEY=
# Copy the exact model id from your Regolo dashboard (e.g. Llama-3.3-70B-Instruct).
REGOLO_MODEL=llama-3.3-70b-instruct

# ---- per-endpoint upstreams ----
# An endpoint can forward passing requests to its own provider. It stores only
# the NAME of the env var that holds the credential (api_key_env) — add the
# actual secret here. Example for an endpoint whose upstream uses OpenAI:
# OPENAI_API_KEY=

# ---- detection ----
# Canary "secret" the offline mock model leaks so you can watch the secret
# detector fire. It is a demo flag, NOT a real credential — replace it.
AEGIS_SECRET=change-me-demo-flag
BLOCK_THRESHOLD=3
JUDGE_ENABLED=true
# Block traffic if the inspection pipeline errors (recommended in production).
AEGIS_FAIL_CLOSED=false
# Default language for the Art. 50 AI disclosure (en, it, de, fr, es). A request's
# Accept-Language header overrides it; unsupported codes fall back to English.
AEGIS_DISCLOSURE_LANG=en

# ---- persistence / eventing ----
# Leave DATABASE_URL empty for sqlite. Set it for a shared, multi-instance audit.
DATABASE_URL=
DB_PATH=aegis.db
# Leave REDIS_URL empty for the in-process event bus. Set it for multi-instance SSE.
REDIS_URL=
AEGIS_SEED=true
# Hash-chain the audit log for tamper-evidence (Art. 12 integrity).
AEGIS_AUDIT_HASH_CHAIN=true
# Storage limitation (GDPR Art. 5(1)(e)): drop audit events older than N days.
# 0 disables retention (audit log grows unbounded, the default).
AEGIS_AUDIT_RETENTION_DAYS=0

# ---- API security (data plane: /v1) ----
# Comma-separated bearer tokens accepted on /v1. Empty = auth disabled.
AEGIS_API_KEYS=
AEGIS_AUTH_ENABLED=false
# Requests per minute per key/ip on /v1. 0 disables.
AEGIS_RATE_LIMIT_RPM=0
# Comma-separated allowed origins for the browser console. Defaults to the dev
# frontend; set this to your real origin(s) in production.
AEGIS_CORS_ORIGINS=http://localhost:5173

# ---- control plane (admin API: /api) ----
# When set, mutating /api/* routes (endpoint & rule edits, demo tamper/reset)
# require this key in the X-API-Key header. Empty = open — only safe on a
# trusted / cluster-internal network.
AEGIS_ADMIN_API_KEY=

# ---- upstream forwarding safety ----
# An endpoint may only reference these env var NAMES for its upstream credential
# (blocks exfiltration of arbitrary process env vars).
AEGIS_UPSTREAM_KEY_ENVS=OPENAI_API_KEY,REGOLO_API_KEY
# Allow forwarding to private / loopback / metadata hosts (disables the SSRF
# guard). Keep this off unless you really need it.
AEGIS_ALLOW_PRIVATE_UPSTREAM=false
