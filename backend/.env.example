# ============================================================
# AEGIS configuration
# With nothing set, AEGIS runs fully offline: mock model, sqlite
# audit, in-memory event bus, no auth. Switch on the hardened
# paths by setting the variables below.
# ============================================================

# ---- model provider ----
# "mock" = deterministic offline vulnerable model. "regolo" = real LLM.
AEGIS_MODE=mock
REGOLO_BASE_URL=https://api.regolo.ai/v1
REGOLO_API_KEY=
# Copy the exact model id from your Regolo dashboard (e.g. Llama-3.3-70B-Instruct).
REGOLO_MODEL=llama-3.3-70b-instruct

# ---- detection ----
AEGIS_SECRET=AEGIS-FLAG-9F2A-7C3E
BLOCK_THRESHOLD=3
JUDGE_ENABLED=true
# Block traffic if the inspection pipeline errors (recommended in production).
AEGIS_FAIL_CLOSED=false

# ---- persistence / eventing ----
# Leave DATABASE_URL empty for sqlite. Set it for a shared, multi-instance audit.
DATABASE_URL=
DB_PATH=aegis.db
# Leave REDIS_URL empty for the in-process event bus. Set it for multi-instance SSE.
REDIS_URL=
AEGIS_SEED=true
# Hash-chain the audit log for tamper-evidence (Art. 12 integrity).
AEGIS_AUDIT_HASH_CHAIN=true

# ---- API security (data plane: /v1) ----
# Comma-separated bearer tokens accepted on /v1. Empty = auth disabled.
AEGIS_API_KEYS=
AEGIS_AUTH_ENABLED=false
# Requests per minute per key/ip on /v1. 0 disables.
AEGIS_RATE_LIMIT_RPM=0
# Comma-separated allowed origins. "*" by default.
AEGIS_CORS_ORIGINS=*
